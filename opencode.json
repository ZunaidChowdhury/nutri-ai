{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "engineering/AGENTS.md",
    "engineering/architecture.md",
    "engineering/tasks.md"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}

